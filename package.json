{
  "name": "@belongnet/capacitor-pass-to-wallet",
  "version": "8.0.0",
  "packageManager": "bun@1.3.7",
  "workspaces": [
    "example"
  ],
  "description": "Allow to add .pkpass files to Apple Wallet",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Sources",
    "ios/Tests",
    "Package.swift",
    "BelongnetCapacitorPassToWallet.podspec"
  ],
  "author": "Valentin Abundo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/belongnet/capacitor-pass-to-wallet.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/belongnet/capacitor-pass-to-wallet/issues"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native",
    "wallet",
    "pkpass",
    "passbook",
    "ionic",
    "apple"
  ],
  "scripts": {
    "verify": "bun run verify:ios && bun run verify:android && bun run verify:web",
    "verify:ios": "xcodebuild -scheme BelongnetCapacitorPassToWallet -destination generic/platform=iOS",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:web": "bun run build",
    "lint": "bun run eslint && bun run prettier -- --check && bun run swiftlint -- lint",
    "fmt": "bun run eslint -- --fix && bun run prettier -- --write && bun run swiftlint -- --fix --format",
    "eslint": "eslint . --ext ts",
    "prettier": "prettier \"**/*.{css,html,ts,js,java}\" --plugin=prettier-plugin-java",
    "swiftlint": "node-swiftlint",
    "docgen": "bunx @capacitor/docgen --api CapacitorPassToWalletPlugin --output-readme README.md --output-json dist/docs.json",
    "build": "bun run clean && bun run docgen && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/docgen": "^0.3.1",
    "@capacitor/ios": "^8.0.0",
    "@ionic/eslint-config": "^0.4.0",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^2.0.0",
    "eslint": "^8.57.1",
    "prettier": "^3.6.2",
    "prettier-plugin-java": "^2.7.7",
    "rimraf": "^6.1.0",
    "rollup": "^4.53.2",
    "swiftlint": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@capacitor/core": ">=8.0.0"
  },
  "prettier": "@ionic/prettier-config",
  "swiftlint": "@ionic/swiftlint-config",
  "eslintConfig": {
    "extends": "@ionic/eslint-config/recommended",
    "overrides": [
      {
        "files": [
          "example/**/*.js"
        ],
        "env": {
          "browser": true,
          "es2022": true
        }
      }
    ]
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "homepage": "https://github.com/belongnet/capacitor-pass-to-wallet#readme",
  "directories": {
    "example": "example"
  }
}